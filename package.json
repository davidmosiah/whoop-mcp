{
  "name": "whoop-mcp-server",
  "version": "0.1.0",
  "description": "Unofficial MCP server for connecting AI agents to the WHOOP API.",
  "type": "module",
  "bin": {
    "whoop-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node scripts/smoke-tools.mjs",
    "test": "npm run typecheck && npm run build && npm run smoke && npm run test:summary",
    "test:summary": "node scripts/summary-fixture-test.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "whoop",
    "wearable",
    "health",
    "fitness",
    "ai-agents"
  ],
  "author": "David Mosiah",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmosiah/whoop-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/davidmosiah/whoop-mcp/issues"
  },
  "homepage": "https://github.com/davidmosiah/whoop-mcp#readme"
}
